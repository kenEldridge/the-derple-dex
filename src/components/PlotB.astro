---
// Panel B: Total dissonance
---

<div id="plot-b"></div>

<script>
	import Plotly from 'plotly.js-dist-min';

	function roughness(deltaF, cbw = 100) {
		const x = deltaF / cbw;
		return Math.exp(-3.5 * x) - Math.exp(-5.75 * x);
	}

	const f0 = 200.0;
	const numPartials = 30;
	const partials = Array.from({length: numPartials}, (_, i) => i + 1);

	const intervals = [
		{name: 'Major third (5:4)', ratio: 5/4},
		{name: 'Perfect fourth (4:3)', ratio: 4/3},
		{name: 'Perfect fifth (3:2)', ratio: 3/2},
		{name: 'Octave (2:1)', ratio: 2.0}
	];

	const ratiosB = Array.from({length: 600}, (_, i) => 1.0 + i * (1.0 / 599));
	const fA = partials.map(p => p * f0);

	const dissonance = ratiosB.map(r => {
		const fB = partials.map(p => p * f0 * r);
		let sum = 0;
		for (let i = 0; i < fA.length; i++) {
			for (let j = 0; j < fB.length; j++) {
				sum += roughness(Math.abs(fA[i] - fB[j]));
			}
		}
		return sum;
	});

	const traceB = {
		x: ratiosB,
		y: dissonance,
		type: 'scatter',
		mode: 'lines',
		line: {color: '#64b5f6', width: 2},
		name: 'Total dissonance'
	};

	// 12-TET reference note positions across one octave.
	// These are optional overlays to compare equal-tempered note placements
	// against local minima/reference interval lines.
	const twelveTetSteps = [
		{semitone: 0, label: 'Unison'},
		{semitone: 1, label: 'm2'},
		{semitone: 2, label: 'M2'},
		{semitone: 3, label: 'm3'},
		{semitone: 4, label: 'M3'},
		{semitone: 5, label: 'P4'},
		{semitone: 6, label: 'TT'},
		{semitone: 7, label: 'P5'},
		{semitone: 8, label: 'm6'},
		{semitone: 9, label: 'M6'},
		{semitone: 10, label: 'm7'},
		{semitone: 11, label: 'M7'},
		{semitone: 12, label: 'Octave'}
	];

	const yMinB = Math.min(...dissonance);
	const yMaxB = Math.max(...dissonance);
	const yPadB = (yMaxB - yMinB) * 0.02;
	const xTet = [];
	const yTet = [];
	const textTet = [];

	for (const step of twelveTetSteps) {
		const ratio = Math.pow(2, step.semitone / 12);
		xTet.push(ratio, ratio, null);
		yTet.push(yMinB - yPadB, yMaxB + yPadB, null);
		textTet.push(
			`${step.label}: 2^(${step.semitone}/12) = ${ratio.toFixed(4)}`,
			`${step.label}: 2^(${step.semitone}/12) = ${ratio.toFixed(4)}`,
			null
		);
	}

	const traceBTwelveTet = {
		x: xTet,
		y: yTet,
		type: 'scatter',
		mode: 'lines',
		line: {color: 'rgba(255,255,255,0.28)', width: 1, dash: 'dot'},
		name: '12-TET note positions',
		visible: false,
		hoverinfo: 'text',
		text: textTet,
		showlegend: false
	};

	const traceBTwelveTetLabels = {
		x: twelveTetSteps.map(step => Math.pow(2, step.semitone / 12)),
		y: twelveTetSteps.map(() => yMaxB + yPadB * 0.1),
		type: 'scatter',
		mode: 'text',
		text: twelveTetSteps.map(step => step.label),
		textposition: 'top center',
		textfont: {color: 'rgba(255,255,255,0.78)', size: 10},
		hoverinfo: 'skip',
		cliponaxis: false,
		visible: false,
		showlegend: false
	};

	const shapesB = intervals.map(interval => ({
		type: 'line',
		x0: interval.ratio,
		x1: interval.ratio,
		y0: 0,
		y1: 1,
		yref: 'paper',
		line: {color: 'rgba(255,255,255,0.4)', width: 1, dash: 'dot'}
	}));

	const layoutB = {
		xaxis: {title: 'Frequency ratio (interval)', gridcolor: 'rgba(255,255,255,0.2)'},
		yaxis: {title: 'Summed dissonance', gridcolor: 'rgba(255,255,255,0.2)'},
		paper_bgcolor: '#000000',
		plot_bgcolor: '#000000',
		font: {color: 'white'},
		shapes: shapesB,
		showlegend: false,
		margin: {l: 60, r: 20, t: 90, b: 60},
		updatemenus: [{
			type: 'buttons',
			direction: 'right',
			x: 1,
			xanchor: 'right',
			y: 1.16,
			yanchor: 'top',
			bgcolor: 'rgba(20,20,20,0.85)',
			bordercolor: 'rgba(255,255,255,0.2)',
			borderwidth: 1,
			active: 0,
			buttons: [
				{
					label: '12-TET: Off',
					method: 'restyle',
					args: [{visible: [true, false, false]}]
				},
				{
					label: '12-TET: Lines',
					method: 'restyle',
					args: [{visible: [true, true, false]}]
				},
				{
					label: '12-TET: Lines+Labels',
					method: 'restyle',
					args: [{visible: [true, true, true]}]
				}
			]
		}]
	};

	const config = {responsive: true};
	Plotly.newPlot('plot-b', [traceB, traceBTwelveTet, traceBTwelveTetLabels], layoutB, config);
</script>

<style>
	#plot-b {
		width: 100%;
		height: 400px;
		margin: 1.5rem 0;
	}
</style>
